       fhir:type ( [
         fhir:code [ fhir:v "boolean"^^xsd:anyURI ]
       ] )
     ] [
       fhir:id [ fhir:v "Extension.extension:documentId" ] ;
       fhir:path [ fhir:v "Extension.extension" ] ;
       fhir:sliceName [ fhir:v "documentId" ] ;
       fhir:short [ fhir:v "Identifiant du document dont est issu la donnée, par exemple le CR-Bio dont est issu une glycémie." ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ]
     ] [
       fhir:id [ fhir:v "Extension.extension:documentId.extension" ] ;
       fhir:path [ fhir:v "Extension.extension.extension" ] ;
       fhir:max [ fhir:v "0" ]
     ] [
       fhir:id [ fhir:v "Extension.extension:documentId.url" ] ;
       fhir:path [ fhir:v "Extension.extension.url" ] ;
       fhir:fixed [
         a fhir:uri ;
         fhir:v "documentId"^^xsd:anyURI
       ]
     ] [
       fhir:id [ fhir:v "Extension.extension:documentId.value[x]" ] ;
       fhir:path [ fhir:v "Extension.extension.value[x]" ] ;
       fhir:type ( [
         fhir:code [ fhir:v "Identifier"^^xsd:anyURI ]
       ] )
     ] [
       fhir:id [ fhir:v "Extension.extension:originalCode" ] ;
       fhir:path [ fhir:v "Extension.extension" ] ;
       fhir:sliceName [ fhir:v "originalCode" ] ;
       fhir:short [ fhir:v "Code original de la donnée. Il permet notamment d'identifier le niveau de comparabilité des résultats entre eux. Le choix a été fait de ne pas indiquer directement le numéro de comparabilité mais d'indiquer directement le code LOINC d'origine pour identifier le numéro de comparabilité dans le jeu de valeur circuit de la biologie." ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ]
     ] [
       fhir:id [ fhir:v "Extension.extension:originalCode.extension" ] ;
       fhir:path [ fhir:v "Extension.extension.extension" ] ;
       fhir:max [ fhir:v "0" ]
     ] [
       fhir:id [ fhir:v "Extension.extension:originalCode.url" ] ;
       fhir:path [ fhir:v "Extension.extension.url" ] ;
       fhir:fixed [
         a fhir:uri ;
         fhir:v "originalCode"^^xsd:anyURI
       ]
     ] [
