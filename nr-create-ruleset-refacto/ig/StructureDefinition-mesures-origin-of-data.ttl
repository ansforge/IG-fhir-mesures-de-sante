  fhir:differential [
     fhir:element ( [
       fhir:id [ fhir:v "Extension" ] ;
       fhir:path [ fhir:v "Extension" ] ;
       fhir:short [ fhir:v "Origine de la donnée" ] ;
       fhir:definition [ fhir:v "Extension pour tracer l'origine de la donnée issue d'un compte rendu de biologie (CR-Bio)." ]
     ] [
       fhir:id [ fhir:v "Extension.extension" ] ;
       fhir:path [ fhir:v "Extension.extension" ] ;
       fhir:min [ fhir:v "3"^^xsd:nonNegativeInteger ]
     ] [
       fhir:id [ fhir:v "Extension.extension:hasBeenConverted" ] ;
       fhir:path [ fhir:v "Extension.extension" ] ;
       fhir:sliceName [ fhir:v "hasBeenConverted" ] ;
       fhir:short [ fhir:v "Indication permettant de savoir si la valeur a été convertie." ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ]
     ] [
       fhir:id [ fhir:v "Extension.extension:hasBeenConverted.extension" ] ;
       fhir:path [ fhir:v "Extension.extension.extension" ] ;
       fhir:max [ fhir:v "0" ]
     ] [
       fhir:id [ fhir:v "Extension.extension:hasBeenConverted.url" ] ;
       fhir:path [ fhir:v "Extension.extension.url" ] ;
       fhir:fixed [
         a fhir:uri ;
         fhir:v "hasBeenConverted"^^xsd:anyURI
       ]
     ] [
       fhir:id [ fhir:v "Extension.extension:hasBeenConverted.value[x]" ] ;
